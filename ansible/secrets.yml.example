# Copy to ansible/secrets.yml (gitignored) and fill in values.
# Loaded automatically by ansible/infra.yml and ansible/services.yml.
#
# Usage:
#   cp ansible/secrets.yml.example ansible/secrets.yml
#   # edit ansible/secrets.yml
#   ansible-playbook ansible/infra.yml
#   ansible-playbook ansible/services.yml

infisical_admin_email: "admin@homelab.local"
infisical_admin_password: "changeme"

authentik_admin_email: "admin@homelab.local"
authentik_admin_password: "changeme"

# Cloudflare Tunnel token for cloudflared on machamp-infra.
# Get it from: cd terraform/machamp && terraform output -raw authentik_tunnel_token
cloudflare_tunnel_token: "REPLACE_ME"

# Public Headscale URL — used as the OIDC redirect URI in Authentik.
# Get it from: cd terraform/diglett && terraform output headscale_url
headscale_public_url: "https://headscale.REPLACE_ME"

# Public Headplane URL — used as the OIDC redirect URI for the headplane provider in Authentik.
# Typically the LAN URL, e.g. https://headplane.home
headplane_public_url: "https://headplane.home"

# Public Authentik URL — used as the OIDC issuer base in headscale config.
# Get it from: cd terraform/machamp && terraform output authentik_public_url
authentik_public_url: "https://auth.REPLACE_ME"

# ── Infisical machine identity for machamp-services ───────────────────────────
# Create via: Infisical UI → Access Control → Machine Identities → Create
# Assign it to your project with "member" role.
# Leave blank to skip secret export during services.yml (can populate homelab.env manually).
infisical_host: "http://192.168.0.32:8080"
infisical_project_id: "REPLACE_ME"   # Settings → Project ID in Infisical UI
infisical_environment: "prod"
infisical_client_id: "REPLACE_ME"
infisical_client_secret: "REPLACE_ME"

# ── NFS source paths on Alakazam ─────────────────────────────────────────────
# Override only if your TrueNAS exports differ from the /mnt/apps/* convention.
# Defaults used by services.yml (leave commented out to use defaults):
# nas_media_path: "192.168.0.4:/mnt/pool/media"
# nas_photos_path: "192.168.0.4:/mnt/pool/photos"
