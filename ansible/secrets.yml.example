# Copy to ansible/secrets.yml (gitignored) and fill in values.
# Loaded automatically by ansible/infra.yml — no env var juggling needed.
#
# Usage:
#   cp ansible/secrets.yml.example ansible/secrets.yml
#   # edit ansible/secrets.yml
#   ansible-playbook ansible/infra.yml

infisical_admin_email: "admin@homelab.local"
infisical_admin_password: "changeme"

authentik_admin_email: "admin@homelab.local"
authentik_admin_password: "changeme"

# Cloudflare Tunnel token for cloudflared on machamp-infra.
# Get it from: cd terraform/machamp && terraform output -raw authentik_tunnel_token
cloudflare_tunnel_token: "REPLACE_ME"

# Public Headscale URL — used as the OIDC redirect URI in Authentik.
# Get it from: cd terraform/diglett && terraform output headscale_url
headscale_public_url: "https://headscale.REPLACE_ME"

# Public Authentik URL — used as the OIDC issuer base in headscale config.
# Get it from: cd terraform/machamp && terraform output authentik_public_url
authentik_public_url: "https://auth.REPLACE_ME"
