# Copy to ansible/secrets.yml (gitignored) and fill in values marked REPLACE_ME.
# Everything else is either optional or auto-populated by ansible/infra.yml.
#
# Usage:
#   cp ansible/secrets.yml.example ansible/secrets.yml
#   # fill in the REPLACE_ME values below
#   ansible-playbook ansible/infra.yml

# ── Infisical admin account ───────────────────────────────────────────────────
infisical_admin_email: "admin@homelab.local"
infisical_admin_password: "REPLACE_ME"

# ── Authentik admin account ───────────────────────────────────────────────────
authentik_admin_email: "admin@homelab.local"
authentik_admin_password: "REPLACE_ME"

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
# Get it from: cd terraform/machamp && terraform output -raw authentik_tunnel_token
cloudflare_tunnel_token: "REPLACE_ME"

# ── Public URLs (used as OIDC redirect URIs and issuer bases) ─────────────────
# Get headscale_public_url from: cd terraform/diglett && terraform output headscale_url
# Get authentik_public_url from: cd terraform/machamp && terraform output authentik_public_url
headscale_public_url: "https://headscale.REPLACE_ME"
headplane_public_url: "https://headplane.home"
authentik_public_url: "https://auth.REPLACE_ME"

# ── Infisical machine identity for machamp-services ───────────────────────────
# Auto-populated by infra.yml on first run (Phase 2).
# Leave as REPLACE_ME — infra.yml replaces them automatically.
infisical_host: "http://192.168.0.32:8080"   # override if Infisical is on a different address
infisical_environment: "prod"
infisical_project_id: "REPLACE_ME"
infisical_client_id: "REPLACE_ME"
infisical_client_secret: "REPLACE_ME"

# ── PIA VPN credential lookup ─────────────────────────────────────────────────
# infra.yml creates a Vaultwarden service account (infra-svc@homelab.local) and
# seeds PIA credentials from it to Infisical. After running infra.yml, log into
# Vaultwarden as that account and add a login item named "PIA VPN".
# Override the item name here only if it differs from the default:
# pia_vault_item: "PIA VPN"

# ── NFS source paths on Alakazam ─────────────────────────────────────────────
# Override only if your TrueNAS exports differ from the defaults below.
# Defaults used by media.yml (leave commented out to use defaults):
# nas_media_path: "192.168.0.4:/mnt/pool/media"
# nas_photos_path: "192.168.0.4:/mnt/pool/photos"
