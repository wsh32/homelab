# Generated by Ansible from network.yml. Do not edit manually.
# Source: ansible/roles/infra/templates/services-vm.yml.j2
#
# File-provider routes for off-host backends.
# Infra services (Infisical, Vaultwarden, Authentik) are handled by Docker labels.
# Each service has both .home (LAN) and .wsh (Tailscale) routers sharing the same backend.
http:
  middlewares:
    # Redirect Jellyfin web UI to Authentik SSO via jellyfin-plugin-sso.
    jellyfin-sso:
      redirectRegex:
        regex: "^https://jellyfin\\.home(/web.*|/?)$"
        replacement: "https://jellyfin.home/SSO/OID/start/authentik"
        permanent: false
    jellyfin-sso-wsh:
      redirectRegex:
        regex: "^https://jellyfin\\.wsh(/web.*|/?)$"
        replacement: "https://jellyfin.wsh/SSO/OID/start/authentik-public"
        permanent: false

    # Authentik forward auth -- all arr/media services require authentication.
    # Authentik proxy providers (forward_auth_single) are bootstrapped by ansible/roles/infra/tasks/main.yml.
    authentik:
      forwardAuth:
        address: "http://authentik-server:9000/outpost.goauthentik.io/auth/traefik"
        trustForwardHeader: true
        authResponseHeaders:
          - X-authentik-username
          - X-authentik-groups
          - X-authentik-email
          - X-authentik-name
          - X-authentik-uid
          - X-authentik-jwt
          - X-authentik-meta-jwks
          - X-authentik-meta-outpost
          - X-authentik-meta-provider
          - X-authentik-meta-app
          - X-authentik-meta-version

  routers:
    # ── Traefik Dashboard ─────────────────────────────────────────────────────
    traefik-home:
      rule: "Host(`traefik.home`)"
      entryPoints: [web]
      service: api@internal
    traefik-home-tls:
      rule: "Host(`traefik.home`)"
      entryPoints: [websecure]
      service: api@internal
      tls:
        certResolver: step
    traefik-wsh-tls:
      rule: "Host(`traefik.wsh`)"
      entryPoints: [websecure]
      service: api@internal
      tls:
        certResolver: step

    # ── Jellyfin ──────────────────────────────────────────────────────────────
    # SSO redirect: web UI paths go to Authentik via jellyfin-plugin-sso.
    # API/app paths (not matching /web or /) pass through directly.
    # Local admin bypass: /web/index.html#!/login.html?mode=0
    jellyfin-sso-redirect:
      rule: "Host(`jellyfin.home`) && Path(`/`)"
      entryPoints: [websecure]
      middlewares: [jellyfin-sso]
      service: jellyfin-svc
      tls:
        certResolver: step
    jellyfin-sso-redirect-wsh:
      rule: "Host(`jellyfin.wsh`) && Path(`/`)"
      entryPoints: [websecure]
      middlewares: [jellyfin-sso-wsh]
      service: jellyfin-svc
      tls:
        certResolver: step
    jellyfin-home:
      rule: "Host(`jellyfin.home`)"
      entryPoints: [web]
      service: jellyfin-svc
    jellyfin-home-tls:
      rule: "Host(`jellyfin.home`)"
      entryPoints: [websecure]
      service: jellyfin-svc
      tls:
        certResolver: step
    jellyfin-wsh-tls:
      rule: "Host(`jellyfin.wsh`)"
      entryPoints: [websecure]
      service: jellyfin-svc
      tls:
        certResolver: step

{% for svc in all_location_services %}
{%   if svc.traefik | default(true) and svc.vm_ip != traefik_ip and svc.name != 'jellyfin' %}
{%     set h = svc.hostname | default(svc.name) %}
{%     set mw = ['authentik'] if svc.authentik == 'proxy' else [] %}
    # ── {{ svc.name }} ──────────────────────────────────────────────────────────
    {{ h }}-home:
      rule: "Host(`{{ h }}.home`)"
      entryPoints: [web]
      service: {{ h }}-svc
{%     if mw %}
      middlewares: {{ mw | to_yaml | trim }}
{%     endif %}
    {{ h }}-home-tls:
      rule: "Host(`{{ h }}.home`)"
      entryPoints: [websecure]
      service: {{ h }}-svc
{%     if mw %}
      middlewares: {{ mw | to_yaml | trim }}
{%     endif %}
      tls:
        certResolver: step
    {{ h }}-wsh-tls:
      rule: "Host(`{{ h }}.wsh`)"
      entryPoints: [websecure]
      service: {{ h }}-svc
{%     if mw %}
      middlewares: {{ mw | to_yaml | trim }}
{%     endif %}
      tls:
        certResolver: step
{%   endif %}
{% endfor %}
    # ── Proxmox ───────────────────────────────────────────────────────────────
    proxmox-home:
      rule: "Host(`proxmox.home`)"
      entryPoints: [web]
      service: proxmox-svc
    proxmox-home-tls:
      rule: "Host(`proxmox.home`)"
      entryPoints: [websecure]
      service: proxmox-svc
      tls:
        certResolver: step

  services:
    jellyfin-svc:
      loadBalancer:
        servers:
          - url: "http://{{ (all_location_services | selectattr('name', 'equalto', 'jellyfin') | list | first).vm_ip }}:{{ (all_location_services | selectattr('name', 'equalto', 'jellyfin') | list | first).port }}"
{% for svc in all_location_services %}
{%   if svc.traefik | default(true) and svc.vm_ip != traefik_ip and svc.name != 'jellyfin' %}
{%     set h = svc.hostname | default(svc.name) %}
{%     set port = svc.host_port | default(svc.port) %}
    {{ h }}-svc:
      loadBalancer:
        servers:
          - url: "http://{{ svc.vm_ip }}:{{ port }}"
{%   endif %}
{% endfor %}
    proxmox-svc:
      loadBalancer:
        serversTransport: insecureTransport
        servers:
{% for node in proxmox_nodes %}
          - url: "https://{{ node.ip }}:8006"   # {{ node.name }}
{% endfor %}

  serversTransports:
    insecureTransport:
      insecureSkipVerify: true
