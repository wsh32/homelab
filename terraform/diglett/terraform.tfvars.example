# Copy to terraform.tfvars and fill in values. NEVER commit terraform.tfvars.

# Proxmox API endpoint for the NUC node
proxmox_endpoint = "https://192.168.0.6:8006"

# Proxmox API token -- create via:
#   Datacenter > Permissions > API Tokens > Add
#   User: terraform@pam, Token ID: terraform, Privilege Separation: unchecked
#   Note: the full token format is "terraform@pam!terraform=<uuid>"
proxmox_api_token = "terraform@pam!terraform=REPLACE_ME"

# Your SSH public key (cat ~/.ssh/id_ed25519.pub)
ssh_public_key = "ssh-ed25519 AAAAC3... you@machine"

# System timezone for all VMs -- use a tz database name (e.g. America/Los_Angeles)
timezone = "UTC"

# Password for the ubuntu user on all VMs (enables console + SSH password login)
vm_password = "REPLACE_ME"

# Cloudflare API token -- create at https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Zone > DNS > Edit and Account > Cloudflare Tunnel > Edit
# Used by Terraform to manage DNS records and the Authentik Cloudflare Tunnel.
cloudflare_api_token = "REPLACE_ME"

# Cloudflare account ID -- owns the Zero Trust tunnels.
# Found in the dashboard URL (dash.cloudflare.com/<account_id>) or any zone's Overview sidebar.
cloudflare_account_id = "REPLACE_ME"

# Zone name that hosts Headscale (headscale.<zone>) and Authentik (auth.<zone>).
# Must be a key in cloudflare_web_zone_ids below.
homelab_zone = "wesleysoohoo.me"

# Subdomain for Headscale -- will create <headscale_subdomain>.<homelab_zone> in Cloudflare DNS
headscale_subdomain = "headscale"

# Subdomain for the public Authentik OIDC endpoint (creates auth.<homelab_zone>)
authentik_subdomain = "auth"

# Cloudflare zone IDs for every zone this stack manages -- the homelab zone plus
# any diglett-web public-service zones (cloudflare_zone values in network.yml).
# Zone ID found in the right sidebar of each zone's Overview page in the Cloudflare dashboard.
cloudflare_web_zone_ids = {
  "wesleysoohoo.me" = "REPLACE_ME"
  "tenderloin.ai"   = "REPLACE_ME"
}
