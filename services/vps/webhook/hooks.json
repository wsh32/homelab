[
  {
    "id": "deploy",
    "execute-command": "/usr/local/bin/forward-to-deploy.sh",
    "trigger-rule": {
      "match": {
        "type": "payload-hmac-sha256",
        "secret": "{{ getenv \"WEBHOOK_SECRET\" }}",
        "parameter": {
          "source": "header",
          "name": "X-Hub-Signature-256"
        }
      }
    }
  }
]
