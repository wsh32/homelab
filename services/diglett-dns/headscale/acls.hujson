{
  "tagOwners": {
    "tag:infra": ["wesoohoo@gmail.com"]
  },
  "autoApprovers": {
    "routes": {
      "0.0.0.0/0": ["tag:infra"],
      "::/0":       ["tag:infra"]
    },
    "exitNode": ["tag:infra"]
  },
  "acls": [
    {
      "action": "accept",
      "src": ["*"],
      "dst": ["*:*"]
    }
  ]
}
