# Fetched at VM boot via: infisical export --format dotenv > /etc/homelab.env
# All values stored in Infisical (machine secrets); never committed here.

# Servarr API keys — deterministic, stored in Infisical
RADARR_API_KEY=
SONARR_API_KEY=
PROWLARR_API_KEY=

# Jellyfin
JELLYFIN_ADMIN_PASSWORD=

# CouchDB (Obsidian LiveSync)
COUCHDB_USER=admin
COUCHDB_PASSWORD=

# PhotoPrism
PHOTOPRISM_ADMIN_PASSWORD=

# n8n
N8N_ENCRYPTION_KEY=

# Grafana
GRAFANA_ADMIN_PASSWORD=

# PIA VPN (Gluetun)
PIA_USERNAME=
PIA_PASSWORD=

# Bazarr
BAZARR_API_KEY=

# Jellyseerr
JELLYSEERR_API_KEY=
