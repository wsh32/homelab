# Fetched at VM boot via: infisical export --format dotenv > /etc/homelab.env
# All values stored in Infisical (machine secrets); never committed here.

MONGO_ROOT_USER=infisical
MONGO_ROOT_PASSWORD=

INFISICAL_AUTH_SECRET=
INFISICAL_ENCRYPTION_KEY=

VAULTWARDEN_ADMIN_TOKEN=
# Set to true only during initial Vaultwarden account creation bootstrap.
VAULTWARDEN_SIGNUPS_ALLOWED=false

AUTHENTIK_DB_USER=authentik
AUTHENTIK_DB_NAME=authentik
AUTHENTIK_DB_PASSWORD=
AUTHENTIK_SECRET_KEY=
