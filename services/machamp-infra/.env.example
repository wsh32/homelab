# Generated once by the infra Ansible role; stored at /etc/homelab.env on machamp-infra.
# NFS-persisted at /mnt/nas/docker/infisical-backups/.secrets.env for rebuild safety.
# Never committed — this file documents the expected variables only.

INFISICAL_DB_USER=infisical
INFISICAL_DB_NAME=infisical
INFISICAL_DB_PASSWORD=

INFISICAL_AUTH_SECRET=
INFISICAL_ENCRYPTION_KEY=

VAULTWARDEN_ADMIN_TOKEN=
# Set to true only during initial Vaultwarden account creation bootstrap.
VAULTWARDEN_SIGNUPS_ALLOWED=false

AUTHENTIK_DB_USER=authentik
AUTHENTIK_DB_NAME=authentik
AUTHENTIK_DB_PASSWORD=
AUTHENTIK_SECRET_KEY=
